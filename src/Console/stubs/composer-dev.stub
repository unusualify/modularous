{
    "name": "unusualify/modularous-dev",
    "type": "project",
    "description": "The Laravel Framework powered with Modularous in development mode.",
    "keywords": [
        "framework",
        "laravel",
        "toolkit",
        "modularous",
        "unusualify",
    ],
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "unusualify/modularous": "*",
    },
    "minimum-stability": "dev",
}
