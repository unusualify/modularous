{
    "name": "unusualify/modularous",
    "type": "library",
    "license": "MIT",
    "description": "Modularous infrastructure for module development",
    "keywords": [
        "unusual",
        "unusualify",
        "modularous",
        "modularous",
        "laravel",
        "vuetify"
    ],
    "authors": [
        {
            "name": "Oğuzhan Bükçüoğlu",
            "email": "oguz.bukcuoglu@gmail.com"
        },
        {
            "name": "Güneş Bizim",
            "email": "gunes@unusualgrowth.com"
        },
        {
            "name": "Hazarcan Doğa Bakan",
            "email": "doga@unusualgrowth.com"
        },
        {
            "name": "İlker Ciblak",
            "email": "ilker@unusualgrowth.com"
        },
        {
            "name": "Erdem Çelik",
            "email": "celikerde@itu.edu.tr"
        }
    ],
    "require": {
        "php": ">=8.2",
        "astrotomic/laravel-translatable": "^11.15",
        "camroncade/timezone": "^0.2",
        "cartalyst/tags": "^14.0",
        "chriskonnertz/deeply": "^2.2",
        "composer/class-map-generator": "^1.7",
        "haydenpierce/class-finder": "^0.5.3",
        "imgix/imgix-php": "^4.1",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^11.51",
        "laravel/horizon": "5.46",
        "laravel/socialite": "^5.27",
        "laravel/telescope": "^5.20",
        "laravel/ui": "^4.6",
        "league/glide-symfony": "^2.1",
        "mcamara/laravel-localization": "^2.0",
        "nwidart/laravel-modules": "^11.0",
        "oguzhanbukcuoglu/laravel-translation": "^11.0",
        "oobook/manage-eloquent": "^1.2",
        "oobook/post-redirector": "^1.0",
        "oobook/priceable": "^1.1",
        "oobook/snapshot": "^2.2",
        "orangehill/iseed": "^3.8",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-permission": "^6.25",
        "spatie/once": "^3.0",
        "tightenco/ziggy": "^2.6",
        "timokoerber/laravel-one-time-operations": "^1.4",
        "torann/geoip": "^3.0",
        "tymon/jwt-auth": "^2.3",
        "unusualify/payable": "^0.12",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "brianium/paratest": "^7.4",
        "doctrine/dbal": "^3.9",
        "fakerphp/faker": "^1.9.1",
        "larastan/larastan": "^2.0",
        "laravel/pint": "^1.18",
        "laravel/sanctum": "^4.0",
        "orchestra/testbench": "^7.0|^8.23.4|^9.0",
        "phpunit/phpunit": "^9.0|^10.0.7|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Unusualify\\Modularous\\LaravelServiceProvider",
                "Unusualify\\Modularous\\Providers\\ModularousProvider"
            ],
            "aliases": {
                "ModularousVite": "Unusualify\\Modularous\\Facades\\ModularousVite"
            }
        },
        "packages": []
    },
    "autoload": {
        "psr-4": {
            "Unusualify\\Modularous\\": "src",
            "Unusualify\\Modularous\\Database\\Seeders\\": "database/seeders",
            "Unusualify\\Modularous\\Database\\Factories\\": "database/factories",
            "Modules\\": "modules"
        },
        "files": [
            "src/Support/Migrations/SchemaParser.php",
            "src/Services/Translation.php",
            "src/Support/ModularousVite.php"
        ],
        "exclude-from-classmap": [
            "../../../vendor/nwidart/laravel-modules/src/Support/Migrations/SchemaParser.php",
            "../../../vendor/joedixon/laravel-translation/src/Drivers/Translation.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Unusualify\\Modularous\\Tests\\": "tests",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/",
            "Modules\\": "tests/Stubs/Modules",
            "TestModules\\": "test-modules"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit  --stop-on-defect --no-coverage",
        "test-clean": [
            "@php -r \"foreach(glob('vendor/orchestra/testbench-core/laravel/bootstrap/cache/*.php') as \\$f) unlink(\\$f);\"",
            "echo 'Test cache cleared'"
        ],
        "test:parallel": [
            "@test-clean",
            "@php -d memory_limit=1G vendor/bin/paratest --processes=2 --stop-on-defect --no-coverage"
        ],
        "test:parallel:coverage": [
            "@test-clean",
            "@php -d memory_limit=1G vendor/bin/paratest --processes=2 --stop-on-defect --coverage-html coverage-html"
        ],
        "test:fast": [
            "@test-clean",
            "@php -d memory_limit=1G vendor/bin/paratest --processes=4 --stop-on-defect --no-coverage"
        ],
        "test:fast:coverage": [
            "@test-clean",
            "@php -d memory_limit=1G vendor/bin/paratest --processes=4 --stop-on-defect --coverage-html coverage-html"
        ],
        "test:brokers": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Brokers",
        "test:events": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Events",
        "test:exceptions": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Exceptions",
        "test:facades": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Facades",
        "test:helpers": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Helpers",
        "test:http": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Http",
        "test:models": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Models",
        "test:repositories": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Repositories",
        "test:services": "vendor/bin/phpunit --stop-on-defect --no-coverage tests/Services",
        "test:stop:defect": "vendor/bin/phpunit --stop-on-defect --no-coverage",
        "test:coverage": "vendor/bin/phpunit --stop-on-defect",
        "test:generated": "vendor/bin/phpunit -c phpunit.generated.xml --stop-on-defect --no-coverage --testsuite Generated",
        "test:coverage:generated": "vendor/bin/phpunit -c phpunit.generated.xml --stop-on-defect --testsuite Generated",
        "test:all": "vendor/bin/phpunit -c phpunit.all.xml --stop-on-defect --no-coverage --testsuite All",
        "test:coverage:all": "vendor/bin/phpunit -c phpunit.all.xml --stop-on-defect --testsuite All",
        "pint": "vendor/bin/pint",
        "pint:test": "vendor/bin/pint --test",
        "pint:bail": "vendor/bin/pint --bail",
        "pint:dirty": "vendor/bin/pint --dirty",
        "pint:repair": "vendor/bin/pint --repair",
        "pint:verbose": "vendor/bin/pint -v",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "php -r \"putenv('CACHE_STORE=array'); putenv('CACHE_DRIVER=array'); passthru('php vendor/bin/testbench package:purge-skeleton --ansi');\"",
        "prepare": "php -r \"putenv('CACHE_STORE=array'); putenv('CACHE_DRIVER=array'); passthru('php vendor/bin/testbench package:discover --ansi');\"",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    }
}
