## Accessors & Mutators

### Accessors (Get Values)

```php
use Illuminate\Database\Eloquent\Casts\Attribute;

// Modern approach (Laravel 9+)
protected function firstName(): Attribute
{
    return Attribute::make(
        get: fn (string $value) => ucfirst($value),
    );
}

protected function fullName(): Attribute
{
    return Attribute::make(
        get: fn () => "{$this->first_name} {$this->last_name}",
    );
}

protected function price(): Attribute
{
    return Attribute::make(
        get: fn (int $value) => $value / 100, // Cents to dollars
    );
}

// Legacy approach (Laravel 8 and below)
public function getFullNameAttribute()
{
    return "{$this->first_name} {$this->last_name}";
}
```

### Mutators (Set Values)

```php
protected function firstName(): Attribute
{
    return Attribute::make(
        get: fn (string $value) => ucfirst($value),
        set: fn (string $value) => strtolower($value),
    );
}

protected function price(): Attribute
{
    return Attribute::make(
        get: fn (int $value) => $value / 100,
        set: fn (float $value) => (int) ($value * 100), // Dollars to cents
    );
}

// Legacy approach
public function setFirstNameAttribute($value)
{
    $this->attributes['first_name'] = strtolower($value);
}
```

## Scopes

### Local Scopes

```php
/**
 * Scope for active records
 * @param \Illuminate\Database\Eloquent\Builder $query
 * @return \Illuminate\Database\Eloquent\Builder
 */
public function scopeActive($query)
{
    return $query->where('status', 'active');
}

/**
 * Scope with parameter
 * @param \Illuminate\Database\Eloquent\Builder $query
 * @param string $status
 * @return \Illuminate\Database\Eloquent\Builder
 */
public function scopeStatus($query, $status)
{
    return $query->where('status', $status);
}

/**
 * Scope for date range
 * @param \Illuminate\Database\Eloquent\Builder $query
 * @param string $startDate
 * @param string $endDate
 * @return \Illuminate\Database\Eloquent\Builder
 */
public function scopeDateRange($query, $startDate, $endDate)
{
    return $query->whereBetween('created_at', [$startDate, $endDate]);
}

/**
 * Scope for search
 * @param \Illuminate\Database\Eloquent\Builder $query
 * @param string $search
 * @return \Illuminate\Database\Eloquent\Builder
 */
public function scopeSearch($query, $search)
{
    return $query->where(function ($q) use ($search) {
        $q->where('name', 'LIKE', "%{$search}%")
          ->orWhere('email', 'LIKE', "%{$search}%");
    });
}

// Usage in Repository filter()
// $query->active(); // No parameters
// $query->status('published'); // With parameter
// $query->dateRange('2024-01-01', '2024-12-31');
```

### Global Scopes

```php
use Illuminate\Database\Eloquent\Builder;
use Illuminate\Database\Eloquent\Scope;

// Create a scope class
class ActiveScope implements Scope
{
    public function apply(Builder $builder, Model $model)
    {
        $builder->where('is_active', true);
    }
}

// Apply in model
protected static function booted()
{
    static::addGlobalScope(new ActiveScope);

    // Or anonymous scope
    static::addGlobalScope('active', function (Builder $builder) {
        $builder->where('is_active', true);
    });
}

// Remove global scope when needed
Model::withoutGlobalScope(ActiveScope::class)->get();
Model::withoutGlobalScope('active')->get();
```

## Events & Observers

### Model Events

```php
protected static function booted()
{
    // Creating event (before save, before created)
    static::creating(function ($model) {
        $model->uuid = Str::uuid();
        $model->slug = Str::slug($model->name);
    });

    // Created event (after save)
    static::created(function ($model) {
        // Send notification
        // Create default relations
    });

    // Updating event (before save, before updated)
    static::updating(function ($model) {
        if ($model->isDirty('status')) {
            $model->status_changed_at = now();
        }
    });

    // Updated event (after save)
    static::updated(function ($model) {
        // Clear cache
    });

    // Saving event (before create/update)
    static::saving(function ($model) {
        // Common validation
    });

    // Saved event (after create/update)
    static::saved(function ($model) {
        // Common post-save actions
    });

    // Deleting event
    static::deleting(function ($model) {
        // Delete related records
        $model->comments()->delete();
    });

    // Deleted event
    static::deleted(function ($model) {
        // Log deletion
    });

    // Restoring event (soft delete)
    static::restoring(function ($model) {
        // Validate restoration
    });

    // Restored event
    static::restored(function ($model) {
        // Restore related records
    });
}
```

### Observers (Recommended for Complex Logic)

```php
// app/Observers/PostObserver.php
class PostObserver
{
    public function creating(Post $post)
    {
        $post->slug = Str::slug($post->title);
    }

    public function created(Post $post)
    {
        // Send notification
    }

    public function updating(Post $post)
    {
        if ($post->isDirty('title')) {
            $post->slug = Str::slug($post->title);
        }
    }

    public function deleted(Post $post)
    {
        // Cleanup
    }
}

// Register in AppServiceProvider
use App\Models\Post;
use App\Observers\PostObserver;

public function boot()
{
    Post::observe(PostObserver::class);
}
```

