## Table Schema Methods

```php
/**
 * Get table columns
 * @return array
 */
public function getTableColumns(): array
{
    return Schema::getColumnListing($this->getTable());
}

/**
 * Check if column exists
 * @param string $column
 * @return bool
 */
public function hasColumn(string $column): bool
{
    return in_array($column, $this->getTableColumns());
}

/**
 * Get fillable columns
 * @return array
 */
public function getFillableColumns(): array
{
    return $this->getFillable();
}

/**
 * Check if attribute is translatable
 * @param string $attribute
 * @return bool
 */
public function isTranslationAttribute(string $attribute): bool
{
    return in_array($attribute, $this->translatedAttributes ?? []);
}
```

## Best Practices

### ✅ DO

```php
// Use casts for type conversion
protected $casts = [
    'is_active' => 'boolean',
    'metadata' => 'array',
];

// Define relationships clearly
public function user()
{
    return $this->belongsTo(User::class);
}

// Use accessors for computed properties
protected function fullName(): Attribute
{
    return Attribute::make(
        get: fn () => "{$this->first_name} {$this->last_name}",
    );
}

// Use scopes for reusable queries
public function scopeActive($query)
{
    return $query->where('is_active', true);
}

// Specify fillable or guarded
protected $fillable = ['name', 'email'];
```

### ❌ DON'T

```php
// Don't put business logic in accessors
protected function total(): Attribute
{
    return Attribute::make(
        get: fn () => $this->calculateComplexTotal(), // ❌ Use method instead
    );
}

// Don't query in accessors
protected function userName(): Attribute
{
    return Attribute::make(
        get: fn () => User::find($this->user_id)->name, // ❌ Use relationship
    );
}

// Don't disable mass assignment protection without reason
protected $guarded = []; // ❌ Too permissive

// Don't use both fillable and guarded
protected $fillable = ['name'];
protected $guarded = ['id']; // ❌ Use one or the other

// Don't put too much logic in events
static::created(function ($model) {
    // 100 lines of code // ❌ Use observer instead
});
```

## Common Patterns

### Soft Deletes

```php
use Illuminate\Database\Eloquent\SoftDeletes;

class Post extends Model
{
    use SoftDeletes;

    protected $dates = ['deleted_at'];
}

// Usage
$post->delete(); // Soft delete
$post->forceDelete(); // Permanent delete
$post->restore(); // Restore
Post::withTrashed()->get(); // Include soft deleted
Post::onlyTrashed()->get(); // Only soft deleted
```

### UUID Primary Key

```php
use Illuminate\Database\Eloquent\Concerns\HasUuids;

class Post extends Model
{
    use HasUuids;

    public $incrementing = false;
    protected $keyType = 'string';
}
```

### Slug Generation

```php
protected static function booted()
{
    static::creating(function ($model) {
        if (empty($model->slug)) {
            $model->slug = Str::slug($model->name);
        }
    });

    static::updating(function ($model) {
        if ($model->isDirty('name') && empty($model->slug)) {
            $model->slug = Str::slug($model->name);
        }
    });
}
```
