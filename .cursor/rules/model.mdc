/**
 * Get relationship type for a given relation
 * @param string $relationName
 * @return string|null
 */
public function getRelationType(string $relationName): ?string
{
    if (!method_exists($this, $relationName)) {
        return null;
    }

    $relation = $this->$relationName();
    return class_basename($relation);
}
