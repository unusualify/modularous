    return $item;
}
```

### Custom Validation

```php
protected function validateFormRequest($schema = [])
{
    $request = parent::validateFormRequest($schema);

    // Additional validation
    if ($this->request->get('email') === 'forbidden@example.com') {
        throw new \Exception('This email is not allowed');
    }

    return $request;
}
