## Custom Methods

```php
/**
 * Custom action
 * @param int $id
 * @return \Illuminate\Http\JsonResponse
 */
public function customAction($id)
{
    $item = $this->repository->getById($id);

    // Perform action
    $item->performAction();

    return $this->respondWithSuccess('Action completed successfully');
}

/**
 * Export data
 * @return \Symfony\Component\HttpFoundation\StreamedResponse
 */
public function export()
{
    $items = $this->repository->list();

    // Export logic
    return Excel::download(new ItemsExport($items), 'items.xlsx');
}

/**
 * Import data
 * @return \Illuminate\Http\JsonResponse
 */
public function import()
{
    $file = $this->request->file('file');

    // Import logic
    Excel::import(new ItemsImport, $file);

    return $this->respondWithSuccess('Data imported successfully');
}
