### Store

```php
/**
 * Store new record
 * @param int|null $parentId
 * @return \Illuminate\Http\JsonResponse
 */
public function store($parentId = null)
{
    $input = $this->validateFormRequest()->all();

    $item = $this->repository->create(
        $input + $this->nestedParentScopes(),
        $this->formSchema
    );

    // Handle different save types
    if (isset($input['cmsSaveType'])) {
        if (Str::endsWith($input['cmsSaveType'], '-close')) {
            return $this->respondWithRedirect($this->getBackLink());
        }
        if (Str::endsWith($input['cmsSaveType'], '-new')) {
            return $this->respondWithRedirect(
                moduleRoute($this->routeName, $this->routePrefix, 'create')
            );
        }
    }

    return $this->respondWithSuccess('Record created successfully');
}
```

### Edit

```php
/**
 * Show edit form
 * @param int $id
 * @return \Illuminate\Http\Response
 */
public function edit($id = null)
{
    $params = $this->request->route()->parameters();
    $id = last($params);

    // For modal editing
    if ($this->getIndexOption('editInModal')) {
        return $this->request->ajax()
            ? Response::json($this->modalFormData($id))
            : Redirect::to(moduleRoute($this->routeName, $this->routePrefix, 'index'));
    }

    return $this->renderForm($this->getFormData($id));
}
```

### Update

```php
/**
 * Update record
 * @param int $id
 * @return \Illuminate\Http\JsonResponse
 */
public function update($id)
{
    $params = $this->request->route()->parameters();
    $id = last($params);

    $input = $this->request->all();

    // Handle cancel
    if (isset($input['cmsSaveType']) && $input['cmsSaveType'] === 'cancel') {
        return $this->respondWithRedirect(
            moduleRoute($this->routeName, $this->routePrefix, 'edit', [$id])
        );
    }

    $formRequest = $this->validateFormRequest();
    $this->repository->update($id, $formRequest->all(), $this->formSchema);

    // Handle different save types
    if (isset($input['cmsSaveType'])) {
        if (Str::endsWith($input['cmsSaveType'], '-close')) {
            return $this->respondWithRedirect($this->getBackLink());
        }
        if (Str::endsWith($input['cmsSaveType'], '-new')) {
            return $this->respondWithRedirect(
                moduleRoute($this->routeName, $this->routePrefix, 'create')
            );
        }
    }

    return $this->respondWithSuccess('Record updated successfully');
}
```

### Show

```php
/**
 * Display single record
 * @param int $id
 * @return \Illuminate\Http\Response
 */
public function show($id)
{
    $params = $this->request->route()->parameters();
    $id = last($params);

    $item = $this->repository->getById($id, with: $this->formWith);

    if ($this->request->ajax()) {
        return Response::json($item->toArray());
    }

    return $this->renderForm($this->getFormData($id));
}
```

### Destroy

```php
/**
 * Delete record (soft delete)
 * @param int $id
 * @return \Illuminate\Http\JsonResponse
 */
public function destroy($id)
{
    $params = $this->request->route()->parameters();
    $id = last($params);

    if ($this->repository->delete($id)) {
        return $this->respondWithSuccess('Record deleted successfully');
    }

    return $this->respondWithError('Cannot delete this record');
}
```

### Additional Actions

```php
/**
 * Duplicate record
 */
public function duplicate($id)
{
    $newItem = $this->repository->duplicate(
        $id,
        $this->titleColumnKey,
        $this->formSchema
    );

    if ($newItem) {
        return Response::json([
            'message' => 'Record duplicated successfully',
            'variant' => 'success',
            'redirector' => moduleRoute($this->routeName, $this->routePrefix, 'edit', [$newItem->id]),
        ]);
    }

    return $this->respondWithError('Failed to duplicate record');
}

/**
 * Restore soft deleted record
 */
public function restore()
{
    if ($this->repository->restore($this->request->get('id'))) {
        return $this->respondWithSuccess('Record restored successfully');
    }

    return $this->respondWithError('Failed to restore record');
}

/**
 * Force delete (permanent)
 */
public function forceDelete()
{
    if ($this->repository->forceDelete($this->request->get('id'))) {
        return $this->respondWithSuccess('Record permanently deleted');
    }

    return $this->respondWithError('Failed to delete record');
}

/**
 * Bulk operations
 */
public function bulkDelete()
{
    $ids = $this->request->get('ids');

    if ($this->repository->bulkDelete($ids)) {
        return $this->respondWithSuccess('Records deleted successfully');
    }

    return $this->respondWithError('Failed to delete records');
}

public function bulkRestore()
{
    $ids = $this->request->get('ids');

    if ($this->repository->bulkRestore($ids)) {
        return $this->respondWithSuccess('Records restored successfully');
    }

    return $this->respondWithError('Failed to restore records');
}

public function bulkForceDelete()
{
    $ids = $this->request->get('ids');

    if ($this->repository->bulkForceDelete($ids)) {
        return $this->respondWithSuccess('Records permanently deleted');
    }

    return $this->respondWithError('Failed to delete records');
}

/**
 * Reorder records (drag & drop)
 */
public function reorder()
{
    $ids = $this->request->get('ids');

    if ($this->repository->setNewOrder($ids)) {
        return $this->respondWithSuccess('Order updated successfully');
    }

    return $this->respondWithError('Failed to update order');
}
```

## Form Configuration

### Form Schema

```php
/**
 * Define or modify form schema
 * @param array $inputs
 * @return array
 */
public function formSchema($inputs)
{
    // Add fields
    $inputs[] = [
        'type' => 'text',
        'name' => 'custom_field',
        'label' => 'Custom Field',
    ];

    // Modify fields
    foreach ($inputs as &$input) {
        if ($input['name'] === 'status') {
            $input['default'] = 'active';
        }
    }

    return $inputs;
}

// Update schema dynamically
public static function updateFormSchema(callable $callback)
{
    // In ServiceProvider or elsewhere
    YourController::updateFormSchema(function ($schema) {
        // Modify schema
        return $schema;
    });
}
```

### Form Data

```php
/**
 * Customize form data
 * @param Request $request
 * @param Model|null $item
 * @return array
 */
public function formData($request, $item = null)
{
    return [
        'customData' => 'value',
        'options' => $this->getOptions(),
        'relatedData' => $item ? $item->getRelatedData() : [],
    ];
}

/**
 * Transform item before form display
 * @param Model $item
 * @return Model
 */
public function formItem(Model $item): Model
{
    // Add computed properties
    $item->custom_field = $item->computeValue();

    return $item;
}
```

