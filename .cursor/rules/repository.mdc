## Best Practices

### ✅ DO

```php
// Return transformed fields
public function prepareFieldsBeforeSave($object, $fields) {
    $fields['slug'] = Str::slug($fields['name']);
    return $fields;
}

// Use afterSave for relationships
public function afterSave($object, $fields) {
    if (isset($fields['tags'])) {
        $object->tags()->sync($fields['tags']);
    }
}

// Check if field should be ignored
if (!$this->shouldIgnoreFieldBeforeSave('field_name')) {
    // Process field
}

// Use trait method discovery
foreach ($this->traitsMethods('afterSave') as $method) {
    $this->$method($object, $fields);
}
```

### ❌ DON'T

```php
// Don't modify object directly in prepare methods
public function prepareFieldsBeforeSave($object, $fields) {
    $object->slug = Str::slug($fields['name']); // ❌ Wrong
    return $fields;
}

// Don't call save() in lifecycle hooks
public function afterSave($object, $fields) {
    $object->save(); // ❌ Wrong - causes infinite loop
}

// Don't perform queries in prepareFields
public function prepareFieldsBeforeSave($object, $fields) {
    $fields['user_name'] = User::find($fields['user_id'])->name; // ❌ Wrong
    return $fields;
}

// Don't modify fields that traits handle
public function afterSave($object, $fields) {
    if ($this->traitHasInput('HasMedia', 'image')) {
        $object->attachMedia($fields['image']); // ❌ Wrong - trait handles it
    }
}
```

## Common Patterns

### Handle Repeater Fields

```php
public function afterSave($object, $fields)
{
    if (isset($fields['addresses'])) {
        // Delete removed addresses
        $keepIds = collect($fields['addresses'])
            ->pluck('id')
            ->filter()
            ->toArray();

        $object->addresses()
            ->whereNotIn('id', $keepIds)
            ->delete();

        // Update or create addresses
        foreach ($fields['addresses'] as $addressData) {
            $object->addresses()->updateOrCreate(
                ['id' => $addressData['id'] ?? null],
                Arr::except($addressData, ['id'])
            );
        }
    }
}
```

### Handle Polymorphic Relations

```php
public function afterSave($object, $fields)
{
    if (isset($fields['taggable_type']) && isset($fields['taggable_id'])) {
        $object->taggable_type = $fields['taggable_type'];
        $object->taggable_id = $fields['taggable_id'];
        $object->saveQuietly(); // Use saveQuietly to avoid retriggering events
    }
}
```

### Cache Expensive Operations

```php
public function getFormFields($object, $fields, $schema)
{
    // Cache expensive computation
    $fields['statistics'] = $this->cacheableField($object->id, 'statistics', function() use ($object) {
        return $object->calculateStatistics();
    });

    return $fields;
}
```

