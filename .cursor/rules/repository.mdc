# Repository Rules - Unusualify Modularity

## Base Structure

```php
namespace Modules\{ModuleName}\Repositories;

use Unusualify\Modularity\Repositories\Repository;

class {ModelName}Repository extends Repository
{
    protected $ignoreFieldsBeforeSave = [];
    protected $fieldsGroups = [];
    protected $traitColumns = [];
}
```

## Lifecycle Hooks (Execution Order)

### Create Flow
```php
prepareFieldsBeforeCreate($fields)
  ↓
beforeSave($object, $fields)
  ↓
prepareFieldsBeforeSave($object, $fields)
  ↓
[Model::create() + save()]
  ↓
afterSave($object, $fields)
```

### Update Flow
```php
beforeSave($object, $fields)
  ↓
prepareFieldsBeforeSave($object, $fields)
  ↓
[Model::fill() + save()]
  ↓
afterSave($object, $fields)
```

### Delete Flow
```php
[Model::delete()]
  ↓
afterDelete($object)
```

## Method Patterns

### Transform Fields (Return Modified Array)

```php
/**
 * Prepare fields before creating model
 * @param array $fields
 * @return array
 */
public function prepareFieldsBeforeCreate($fields)
{
    // Encrypt sensitive data
    if (isset($fields['password'])) {
        $fields['password'] = Hash::make($fields['password']);
    }

    // Set defaults
    $fields['status'] ??= 'draft';

    return $fields;
}

/**
 * Prepare fields before saving (create/update)
 * @param \Illuminate\Database\Eloquent\Model $object
 * @param array $fields
 * @return array
 */
public function prepareFieldsBeforeSave($object, $fields)
{
    // Handle JSON columns
    if (isset($fields['metadata->key'])) {
        // Will be handled by ManageTraits
    }

    // Transform data
    if (isset($fields['price'])) {
        $fields['price'] = (int) ($fields['price'] * 100); // Store as cents
    }

    return $fields;
}

/**
 * Clean up checkboxes and nullable fields
 * @param \Illuminate\Database\Eloquent\Model|null $object
 * @param array $fields
 * @return array
 */
public function cleanupFields($object, $fields)
{
    // Checkboxes default to false if not present
    foreach ($this->model->checkboxes ?? [] as $field) {
        if (!$this->shouldIgnoreFieldBeforeSave($field)) {
            $fields[$field] = !empty($fields[$field]);
        }
    }

    // Nullable fields default to null if not present
    foreach ($this->model->nullable ?? [] as $field) {
        if (!isset($fields[$field]) && !$this->shouldIgnoreFieldBeforeSave($field)) {
            $fields[$field] = null;
        }
    }

    return $fields;
}
```

### Lifecycle Side Effects (No Return Value)

```php
/**
 * Execute before model save (validation, checks)
 * @param \Illuminate\Database\Eloquent\Model $object
 * @param array $fields
 * @return void
 */
public function beforeSave($object, $fields)
{
    // Validation
    if (isset($fields['email']) && $object->isDirty('email')) {
        // Check if email is unique
        if ($this->model->where('email', $fields['email'])
            ->where('id', '!=', $object->id)
            ->exists()) {
            throw new \Exception('Email already exists');
        }
    }

    // Set computed fields
    $object->slug = Str::slug($fields['name'] ?? $object->name);
}

/**
 * Execute after model save (relations, media, files)
 * @param \Illuminate\Database\Eloquent\Model $object
 * @param array $fields
 * @return void
 */
public function afterSave($object, $fields)
{
    // Sync relationships
    if (isset($fields['categories'])) {
        $object->categories()->sync($fields['categories']);
    }

    // Handle many-to-many with pivot data
    if (isset($fields['tags'])) {
        $tags = collect($fields['tags'])->mapWithKeys(function($tag) {
            return [$tag['id'] => ['order' => $tag['order']]];
        });
        $object->tags()->sync($tags);
    }

    // Update related models
    if (isset($fields['settings'])) {
        foreach ($fields['settings'] as $key => $value) {
            $object->settings()->updateOrCreate(
                ['key' => $key],
                ['value' => $value]
            );
        }
    }
}

/**
 * Execute after model deletion
 * @param \Illuminate\Database\Eloquent\Model $object
 * @return void
 */
public function afterDelete($object)
{
    // Cascade delete related records
    $object->comments()->delete();

    // Delete files
    Storage::delete($object->getMediaPaths());
}

/**
 * Execute after force deletion
 * @param \Illuminate\Database\Eloquent\Model $object
 * @return void
 */
public function afterForceDelete($object)
{
    // Permanent cleanup
    $object->media()->forceDelete();
}

/**
 * Execute after model restoration
 * @param \Illuminate\Database\Eloquent\Model $object
 * @return void
 */
public function afterRestore($object)
{
    // Restore related records
    $object->comments()->onlyTrashed()->restore();
}
```

## Form Fields Transformation

```php
/**
 * Get form fields from model (model → form)
 * @param \Illuminate\Database\Eloquent\Model $object
 * @param array $fields
 * @param array $schema
 * @return array
 */
public function getFormFields($object, $fields, $schema)
{
    // Transform database values for form
    if (isset($fields['price'])) {
        $fields['price'] = $fields['price'] / 100; // Cents to dollars
    }

    // Load relationship data
    if ($this->traitHasInput('HasCategories', 'categories')) {
        $fields['categories'] = $object->categories->pluck('id')->toArray();
    }

    // Handle JSON fields
    if (isset($object->metadata)) {
        foreach ($object->metadata as $key => $value) {
            $fields["metadata.$key"] = $value;
        }
    }

    // Transform dates
    if (isset($fields['published_at'])) {
        $fields['published_at'] = $object->published_at?->format('Y-m-d H:i');
    }

    return $fields;
}

/**
 * Get show/display fields from model
 * @param \Illuminate\Database\Eloquent\Model $object
 * @param array $fields
 * @param array $schema
 * @return array
 */
public function getShowFields($object, $fields, $schema)
{
    // Similar to getFormFields but may include computed properties
    $fields['full_name'] = $object->full_name;
    $fields['status_label'] = $object->getStatusLabel();

    return $fields;
}
```

## Query Methods

### Filtering

```php
/**
 * Apply filters to query
 * @param \Illuminate\Database\Eloquent\Builder $query
 * @param array $scopes
 * @return \Illuminate\Database\Eloquent\Builder
 */
public function filter($query, array $scopes = [])
{
    // Status filter
    if (isset($scopes['status'])) {
        $query->where('status', $scopes['status']);
        unset($scopes['status']);
    }

    // Date range
    if (isset($scopes['start_date'])) {
        $query->where('created_at', '>=', $scopes['start_date']);
        unset($scopes['start_date']);
    }

    // Relationship filter
    $this->addRelationFilterScope($query, $scopes, 'category_id', 'category');

    // Search in relationships
    $this->searchInRelationships($query, $scopes, 'search', [
        'user.name',
        'user.email',
        'category.name'
    ]);

    return parent::filter($query, $scopes);
}

/**
 * Apply ordering to query
 * @param \Illuminate\Database\Eloquent\Builder $query
 * @param array $orders
 * @return \Illuminate\Database\Eloquent\Builder
 */
public function order($query, array $orders = [])
{
    // Custom ordering logic
    if (isset($orders['priority'])) {
        $query->orderByRaw('FIELD(priority, "high", "medium", "low")');
        unset($orders['priority']);
    }

    return parent::order($query, $orders);
}
```

### Counting

```php
/**
 * Get count by status slug
 * @param string $slug
 * @return int|false
 */
public function getCountByStatusSlug($slug)
{
    switch ($slug) {
        case 'pending':
            return $this->model->where('status', 'pending')->count();
        case 'approved':
            return $this->model->where('status', 'approved')->count();
        default:
            return false; // Let parent handle it
    }
}
```

## Trait Integration

### Using Trait Methods

```php
// In any lifecycle method
public function afterSave($object, $fields)
{
    // Manually call specific trait methods if needed
    foreach ($this->traitsMethods(__FUNCTION__) as $method) {
        $this->$method($object, $fields);
    }

    // Or add your logic that will be called alongside trait methods
    $this->updateCache($object);
}
```

### Checking Trait Columns

```php
public function prepareFieldsBeforeSave($object, $fields)
{
    // Check if a trait handles this field
    if ($this->traitHasInput('HasMedia', 'featured_image')) {
        // Let trait handle it
        unset($fields['featured_image']);
    }

    return $fields;
}
```

### Setting Trait Columns

```php
/**
 * Set columns for trait tracking
 * @param array $columns
 * @param array $inputs
 * @return array
 */
public function setColumns($columns, $inputs)
{
    // Register columns that your repository handles
    $columns['MyCustomTrait'] = ['custom_field_1', 'custom_field_2'];

    return $columns;
}
```

## Relationship Helpers

```php
/**
 * Update one-to-many relationship
 */
public function afterSave($object, $fields)
{
    if (isset($fields['phones'])) {
        // Delete removed phones
        $object->phones()
            ->whereNotIn('id', array_column($fields['phones'], 'id'))
            ->delete();

        // Update or create phones
        foreach ($fields['phones'] as $phoneData) {
            $object->phones()->updateOrCreate(
                ['id' => $phoneData['id'] ?? null],
                $phoneData
            );
        }
    }
}

/**
 * Update many-to-many relationship
 */
public function afterSave($object, $fields)
{
    // Simple sync
    $this->updateMultiSelect($object, $fields, 'roles');

    // Or with pivot data
    if (isset($fields['permissions'])) {
        $sync = collect($fields['permissions'])->mapWithKeys(function($perm) {
            return [$perm['id'] => ['granted_at' => now()]];
        });
        $object->permissions()->sync($sync);
    }
}
```

